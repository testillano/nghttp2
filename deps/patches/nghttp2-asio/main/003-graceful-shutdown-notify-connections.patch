 void server::stop() {
+  std::lock_guard<std::mutex> guard(mutex_);
+
   for (auto &acceptor : acceptors_) {
     acceptor.close();
   }
+
+  for (auto *conn : ssl_connections_) {
+    conn->notify_shutdown();
+  }
+  for (auto *conn : plain_connections_) {
+    conn->notify_shutdown();
+  }
+
+  ssl_connections_.clear();
+  plain_connections_.clear();
+
   io_service_pool_.stop();
 }

